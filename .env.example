# ============================================================
# mem0-stack-oss — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the required values.
#
# Minimum required:
#   OPENAI_API_KEY   — for LLM extraction + embeddings
#   PG_PASSWORD      — PostgreSQL password
# ============================================================

# --- Required ---
OPENAI_API_KEY=sk-your-openai-key
PG_PASSWORD=change-me-in-production

# --- LLM (extraction + memory actions) ---
# Default: OpenAI gpt-4.1-nano. Override for other providers.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4.1-nano-2025-04-14
# LLM_API_KEY=                # defaults to OPENAI_API_KEY
# LLM_BASE_URL=               # set for non-OpenAI (e.g. https://api.cerebras.ai/v1)
# LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=8192

# --- Embedder ---
# EMBEDDER_PROVIDER=openai
# EMBEDDER_MODEL=text-embedding-3-small
# EMBEDDER_DIMS=1536
# EMBEDDER_API_KEY=            # defaults to OPENAI_API_KEY

# --- Graph LLM (optional, defaults to main LLM) ---
# GRAPH_LLM_PROVIDER=openai
# GRAPH_LLM_MODEL=
# GRAPH_LLM_API_KEY=
# GRAPH_LLM_BASE_URL=

# --- Fallback LLM (optional, used on 3rd retry) ---
# FALLBACK_LLM_PROVIDER=openai
# FALLBACK_LLM_MODEL=gpt-4.1-nano
# FALLBACK_LLM_API_KEY=
# FALLBACK_LLM_BASE_URL=

# --- Reranker (optional) ---
# Enable TEI reranker: set RERANKER_PROVIDER=tei and start with --profile gpu
# RERANKER_PROVIDER=tei
# RERANKER_BASE_URL=http://reranker:80
# RERANKER_TOP_K=5
# RERANKER_TIMEOUT=10
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Classification (optional, runs after each add) ---
# CLASSIFY_ENABLED=true
# CLASSIFY_MODEL=              # defaults to LLM_MODEL
# CLASSIFY_API_KEY=            # defaults to LLM_API_KEY
# CLASSIFY_BASE_URL=           # defaults to LLM_BASE_URL

# --- Verification (optional, disabled by default) ---
# VERIFY_ENABLED=false
# VERIFY_PROVIDER=openai
# VERIFY_MODEL=
# VERIFY_API_KEY=

# --- Auth (optional, leave empty for no auth) ---
# ADMIN_API_KEY=
# MAINTENANCE_API_KEY=

# --- PostgreSQL ---
# PG_DB=mem0
# PG_USER=mem0
# PG_PORT=5432

# --- FalkorDB ---
# FALKORDB_PORT=6379
# FALKORDB_DATABASE=mem0

# --- Dashboard ---
# DASHBOARD_PORT=8080

# --- Reranker GPU (with --profile gpu) ---
# RERANKER_PORT=8184
