# --- LLM (any OpenAI-compatible endpoint) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-nano-2025-04-14
LLM_API_KEY=           # falls back to OPENAI_API_KEY
# LLM_BASE_URL=        # set for non-OpenAI providers (e.g. https://api.cerebras.ai/v1)
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=8192

# --- Embedder ---
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small
EMBEDDER_DIMS=1536
# EMBEDDER_API_KEY=    # falls back to OPENAI_API_KEY

# --- Reranker (optional, leave empty to disable) ---
# RERANKER_PROVIDER=huggingface
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_DEVICE=cpu
# RERANKER_TOP_K=5
# --- TEI reranker (when RERANKER_PROVIDER=tei) ---
# RERANKER_BASE_URL=http://localhost:8184
# RERANKER_TIMEOUT=10

# --- Graph store (falkordb or neo4j) ---
GRAPH_PROVIDER=falkordb
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_DATABASE=mem0
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=mem0graph

# --- Graph LLM (optional, falls back to main LLM) ---
# GRAPH_LLM_PROVIDER=openai
# GRAPH_LLM_MODEL=gpt-4.1-nano
# GRAPH_LLM_API_KEY=
# GRAPH_LLM_BASE_URL=

# --- Fallback LLM (optional, used when primary LLM fails) ---
# FALLBACK_LLM_MODEL=gpt-4.1-nano
# FALLBACK_LLM_API_KEY=

# --- PostgreSQL (pgvector) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_COLLECTION_NAME=memories
# PG_POOL_MIN=2
# PG_POOL_MAX=80

# --- Classification pipeline (runs after each add) ---
# CLASSIFY_ENABLED=true
# CLASSIFY_MODEL=              # defaults to LLM_MODEL
# CLASSIFY_API_KEY=            # defaults to LLM_API_KEY
# CLASSIFY_BASE_URL=           # defaults to LLM_BASE_URL

# --- Verification (optional second LLM to verify classification) ---
# VERIFY_ENABLED=false
# VERIFY_PROVIDER=openai       # or "anthropic"
# VERIFY_MODEL=
# VERIFY_API_KEY=

# --- Auth ---
# ADMIN_API_KEY=       # set to enable API key authentication on all endpoints
# MAINTENANCE_API_KEY= # set to protect maintenance/admin endpoints

# --- History ---
# HISTORY_DB_PATH=/app/history/history.db

# --- Legacy (still accepted, used as fallback for LLM_API_KEY / EMBEDDER_API_KEY) ---
# OPENAI_API_KEY=
